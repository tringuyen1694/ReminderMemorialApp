{
  "expo": {
    "name": "Ngày kỷ niệm",
    "slug": "memorial-lunar-reminder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.memorialreminder"
    },
    "android": {
      "package": "com.yourname.memorialreminder",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": ["SCHEDULE_EXACT_ALARM", "POST_NOTIFICATIONS"]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#378ADD"
        }
      ]
    ]
  }
}
