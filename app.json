{
  "expo": {
    "name": "Ngày kỷ niệm",
    "slug": "memorial-lunar-reminder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.johnny.memorialreminder"
    },
    "android": {
      "package": "com.johnny.memorialreminder",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": ["SCHEDULE_EXACT_ALARM", "POST_NOTIFICATIONS"]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#378ADD"
        }
      ]
    ],
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "extra": {
      "eas": {
        "projectId": "6b6a8ad7-1fe6-48b7-809b-53e62e77cebb"
      }
    }
  }
}
